format = """
[](fg:#8B72AE)[ ](bg:#8B72AE fg:#ffffff)$directory[](bg:#96899D fg:#8B72AE)$username[](bg:#5B4B65 fg:#96899D)$hostname[](fg:#5B4B65)$cmd_duration$jobs$git_branch$git_metrics$git_status$fill$time$sudo$line_break$character
"""

command_timeout = 2000
scan_timeout = 500
add_newline = true

[character]
success_symbol = "[λ](bold #7E6588)"
error_symbol = "[Δ](bold #5B4B65)"

[directory]
truncation_length = 3
truncation_symbol = ".../"
read_only = "  "
style = "bg:#8B72AE fg:#ffffff"
format = "[ $path ]($style)"

[fill]
symbol = " "

[cmd_duration]
min_time = 5
format = "[   $duration ](bold #ffffff)"

[hostname]
ssh_only = false
style = "bg:#5B4B65 fg:#ffffff"
format = "[ $hostname ]($style)"

[git_branch]
style = "fg:#ffffff"

[jobs]
symbol_threshold = 1
number_threshold = 2
symbol = "󱐌"
format = "[$symbol$number](bold #ffffff)"

[username]
show_always = true
style_user = "bg:#96899D fg:#ffffff"
style_root = "bg:#C099D3 fg:#D7C4E1"
format = "[ $user ]($style)"

[time]
disabled = false
format = "[$time](#ffffff)"
use_12hr = true
time_format = "%T"
utc_time_offset = "local"

[sudo]
symbol = " 󰐼 "
disabled = false
format = "[$symbol](bold #5B4B65)"

[line_break]
disabled = false
