format = """
[](fg:#888782)[ ](bg:#888782 fg:#ffffff)$directory[](bg:#575757 fg:#888782)$username[](bg:#960B0D fg:#575757)$hostname[](fg:#960B0D)$cmd_duration$jobs$git_branch$git_metrics$git_status$fill$time$line_break$character
"""

command_timeout = 2000
scan_timeout = 500
add_newline = true

[character]
success_symbol = "[λ](bold #8E545A)"
error_symbol = "[Δ](bold #960B0D)"

[directory]
truncation_length = 3
truncation_symbol = ".../"
read_only = "  "
style = "bg:#888782 fg:#ffffff"
format = "[ $path ]($style)"

[fill]
symbol = " "

[cmd_duration]
min_time = 5
format = "[   $duration ](bold #ffffff)"

[hostname]
ssh_only = false
style = "bg:#960B0D fg:#ffffff"
format = "[ $hostname ]($style)"

[git_branch]
style = "fg:#ffffff"

[jobs]
symbol_threshold = 1
number_threshold = 2
symbol = "󱐌"
format = "[$symbol$number](bold #ffffff)"

[username]
show_always = true
style_user = "bg:#575757 fg:#ffffff"
style_root = "bg:#0B0B0B fg:#7C7D7D"
format = "[ $user ]($style)"

[time]
disabled = false
format = "[$time](#ffffff)"
use_12hr = true
time_format = "%T"
utc_time_offset = "local"

[sudo]
symbol = " 󰐼 "
disabled = false
format = "[$symbol](bold #960B0D)"

[line_break]
disabled = false
